#!/usr/bin/env node

import fs from 'fs';
import path from 'path';
import readline from 'readline';
import { execSync, exec } from 'child_process';
import { fileURLToPath } from 'url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const dbJsonPath = path.resolve(__dirname, "bot_database.json");

function clearScreen() {
  process.stdout.write('\x1Bc');
}

function printHeader() {
  console.log("\x1b[36m====================================================\x1b[0m");
  console.log("\x1b[1m\x1b[35m        🛠️  DALTOON STORE CLI CONFIGURATION PANEL     \x1b[0m");
  console.log("\x1b[36m====================================================\x1b[0m");
}

function readDb() {
  try {
    if (fs.existsSync(dbJsonPath)) {
      return JSON.parse(fs.readFileSync(dbJsonPath, 'utf8'));
    }
  } catch (e) {
    // Return empty fallback
  }
  return { settings: {} };
}

function writeDb(db) {
  try {
    fs.writeFileSync(dbJsonPath, JSON.stringify(db, null, 2), 'utf8');
    return true;
  } catch (e) {
    console.log("\x1b[31mError saving database file:\x1b[0m", e.message);
    return false;
  }
}

const rl = readline.createInterface({
  input: process.stdin,
  output: process.stdout
});

function ask(query) {
  return new Promise((resolve) => {
    rl.question(query, (ans) => {
      resolve(ans);
    });
  });
}

async function mainMenu() {
  while (true) {
    clearScreen();
    printHeader();
    const db = readDb();
    const config = db.settings && db.settings.panel_config ? JSON.parse(db.settings.panel_config) : {};
    
    const port = config.serverPort || 3000;
    const user = config.dashboardUsername || "Daltoon";
    const pass = config.dashboardPassword || "Daltoon10";
    
    console.log(`\x1b[33m[1]\x1b[0m 🔄 Update (آپدیت مستقل پروژه)`);
    console.log(`\x1b[33m[2]\x1b[0m 🚀 Start (استارت پورت و چدهای پس‌زمینه)`);
    console.log(`\x1b[33m[3]\x1b[0m 🛑 Stop (متوقف کردن موقت سرویس‌ها)`);
    console.log(`\x1b[33m[4]\x1b[0m ♻️ Restart (راه‌اندازی مجدد سریع)`);
    console.log(`\x1b[33m[5]\x1b[0m 🔑 Change Username & Password (کنترل دسترسی داشبورد)`);
    console.log(`\x1b[33m[6]\x1b[0m 🔌 Change Port (تغییر پورت سرور) [Current: \x1b[32m${port}\x1b[0m]`);
    console.log(`\x1b[33m[7]\x1b[0m 🚪 Exit (خروج)`);
    console.log("\x1b[36m====================================================\x1b[0m");
    
    const choice = await ask("\x1b[1mSelect option [1-7]: \x1b[0m");
    
    if (choice === '1') {
      clearScreen();
      printHeader();
      console.log("\x1b[33m=== UPDATING DALTOON PROJECT ===\x1b[0m");
      console.log("Checking and executing update operations...");
      try {
        console.log("Pulling latest code changes from repository...");
        execSync("git pull", { stdio: "inherit" });
        console.log("Installing node modules...");
        execSync("npm install", { stdio: "inherit" });
        console.log("Building production target bundles...");
        execSync("npm run build", { stdio: "inherit" });
        console.log("\n\x1b[32m✔ Project updated successfully!\x1b[0m");
      } catch (err) {
        console.log("\x1b[31mError during update operations:\x1b[0m", err.message);
      }
      await ask("\nPress ENTER to return to main menu...");
    } 
    else if (choice === '2') {
      clearScreen();
      printHeader();
      console.log("\x1b[33m=== STARTING DALTOON SERVICES ===\x1b[0m");
      try {
        console.log("Starting Web Dashboard and Bot processes under PM2...");
        try { execSync("pm2 start dist/server.cjs --name 'daltoon-store' || pm2 start daltoon-store || pm2 restart daltoon-store", { stdio: "inherit" }); } catch(e){}
        try { execSync("pm2 start bot.py --name 'daltoon-bot' --interpreter python3 || pm2 start daltoon-bot || pm2 restart daltoon-bot", { stdio: "inherit" }); } catch(e){}
        
        console.log("\n\x1b[32m✔ Services started/restarted successfully via PM2!\x1b[0m");
      } catch (err) {
        console.log("\x1b[31mError starting services:\x1b[0m", err.message);
      }
      await ask("\nPress ENTER to return to main menu...");
    }
    else if (choice === '3') {
      clearScreen();
      printHeader();
      console.log("\x1b[33m=== STOPPING SERVICES ===\x1b[0m");
      try {
        console.log("Stopping PM2 managed services...");
        try { execSync("pm2 stop daltoon-store || true"); } catch(e){}
        try { execSync("pm2 stop daltoon-bot || true"); } catch(e){}
        console.log("\n\x1b[32m✔ Services stopped successfully via PM2 on server!\x1b[0m");
      } catch (err) {
        console.log("\x1b[31mError stopping services:\x1b[0m", err.message);
      }
      await ask("\nPress ENTER to return to main menu...");
    }
    else if (choice === '4') {
      clearScreen();
      printHeader();
      console.log("\x1b[33m=== RESTARTING SERVICES ===\x1b[0m");
      try {
        console.log("Restarting PM2 managed services...");
        try { execSync("pm2 restart daltoon-store || true"); } catch(e){}
        try { execSync("pm2 restart daltoon-bot || true"); } catch(e){}
        
        console.log("\n\x1b[32m✔ Services restarted successfully via PM2!\x1b[0m");
      } catch (err) {
        console.log("\x1b[31mError restarting services:\x1b[0m", err.message);
      }
      await ask("\nPress ENTER to return to main menu...");
    }
    else if (choice === '5') {
      clearScreen();
      printHeader();
      console.log("\x1b[33m=== CHANGE DASHBOARD CREDENTIALS ===\x1b[0m");
      console.log(`Current Username: \x1b[35m${user}\x1b[0m`);
      console.log(`Current Password: \x1b[35m${pass}\x1b[0m`);
      const newUsername = await ask("Enter new Username (Leave empty to keep current): ");
      const newPassword = await ask("Enter new Password (Leave empty to keep current): ");
      
      let updated = false;
      if (newUsername.trim()) {
        config.dashboardUsername = newUsername.trim();
        updated = true;
      }
      if (newPassword.trim()) {
        config.dashboardPassword = newPassword.trim();
        updated = true;
      }
      
      if (updated) {
        db.settings.panel_config = JSON.stringify(config);
        if (writeDb(db)) {
          console.log(`\n\x1b[32m✔ Dashboard credentials successfully updated!\x1b[0m`);
        }
      } else {
        console.log("\nNo changes made.");
      }
      await ask("\nPress ENTER to return to main menu...");
    }
    else if (choice === '6') {
      clearScreen();
      printHeader();
      console.log("\x1b[33m=== CHANGE PORT ===\x1b[0m");
      console.log(`Current server port is: \x1b[35m${port}\x1b[0m`);
      const newPortStr = await ask("Enter new server port (e.g. 5000): ");
      const newPort = parseInt(newPortStr, 10);
      if (newPort > 0 && newPort < 65536) {
        config.serverPort = newPort;
        db.settings.panel_config = JSON.stringify(config);
        if (writeDb(db)) {
          console.log(`\n\x1b[32m✔ Server Port successfully changed to ${newPort}!\x1b[0m`);
          console.log(`Please restart the server to bind to this new port.`);
        }
      } else {
        console.log("\n\x1b[31mInvalid port number!\x1b[0m Port must be between 1 and 65535.");
      }
      await ask("\nPress ENTER to return to main menu...");
    }
    else if (choice === '7') {
      console.log("\n\x1b[32mGoodbye!\x1b[0m\n");
      rl.close();
      break;
    }
  }
}

mainMenu();
